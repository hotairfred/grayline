__pycache__/
*.pyc
# Credentials / API keys — never commit (the *.example templates ARE committed)
secrets.json
# Operator-specific settings (callsign, grid, hosts) — copy from config.json.example
config.json
# Runtime data, caches, and logs — regenerated/re-fetched by the app, not source
qrz_cache.json
ja_pref_cache.json
qrz_logbook.json
qrz_logbook.adi
# LoTW fetch state + confirmation data and the live WSJT-X QSO log (all runtime data)
lotw_state.json
lotw_qsl.adi
# LoTW user-activity roster cache (re-fetched weekly from ARRL; ~5.5MB)
lotw_activity.json
qso_logged.adi
*.log
*.bak
# Vendor reference PDFs (DXLab manuals etc.) — re-downloadable, not our work
docs/dxlab/*.pdf
# Vendor source clones for cross-reference (GridTracker2, etc.) — re-cloneable
vendor/
clublog_breaker.json
*.bak.*

# Personal Club Log match data (your QSOs) — regenerated weekly
data/clublog_matches.json

# M0OXO OQRS callsign-search results (personal QSO data, manual paste)
data/m0oxo_matches.json
